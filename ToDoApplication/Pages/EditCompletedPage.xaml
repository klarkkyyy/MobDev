<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="ToDoApplication.Pages.EditCompletedPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Label Text="Edit Completed Task" FontSize="22" Grid.Row="0" />

        <Frame Grid.Row="1" CornerRadius="10" Padding="12" HasShadow="True" BackgroundColor="{StaticResource White}">
            <VerticalStackLayout Spacing="10">
                <Entry Text="{Binding item_name}" Placeholder="Task Name" TextColor="{StaticResource Black}" />
                <Editor Text="{Binding item_description}" Placeholder="Description" AutoSize="TextChanges" HeightRequest="100" TextColor="{StaticResource Black}" />
            </VerticalStackLayout>
        </Frame>

        <HorizontalStackLayout Grid.Row="2" Spacing="10">
            <Button Text="Save" Clicked="OnSaveClicked" BackgroundColor="{StaticResource Primary}" TextColor="Black" HorizontalOptions="FillAndExpand" />
            <Button Text="Delete" Clicked="OnDeleteClicked" BackgroundColor="Transparent" TextColor="Red" />
        </HorizontalStackLayout>
    </Grid>

</ContentPage>