<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:ToDo_ListView.PageModels"
             xmlns:models="clr-namespace:ToDoMaui_Listview"
             x:Class="ToDo_ListView.Pages.MainPage"
             x:DataType="pageModels:MainPageModel"
             x:Name="OverviewPage"
             Title="{Binding Today}">

    <VerticalStackLayout Spacing="10" VerticalOptions="Fill" HorizontalOptions="Fill">

        <!-- Input Section -->
        <VerticalStackLayout Padding="10" Spacing="8" BackgroundColor="White" Margin="0,0,0,5">
            <Label Text="📝 My To-Do List" FontSize="20" FontAttributes="Bold"
                   TextColor="#333" HorizontalOptions="Center"/>

            <Entry x:Name="titleEntry"
                   Placeholder="Title (required)"
                   PlaceholderColor="Gray"
                   TextColor="Black"
                   BackgroundColor="#F5F5F5"
                   Keyboard="Text"
                   ReturnType="Next"
                   MaxLength="50"/>

            <Editor x:Name="detailsEditor"
                    Placeholder="Details (optional)"
                    PlaceholderColor="Gray"
                    TextColor="Black"
                    BackgroundColor="#F5F5F5"
                    MaxLength="240"
                    Keyboard="Text"
                    HeightRequest="80"/>

            <!-- Add Button -->
            <Button x:Name="addBtn"
                    Text="＋ Add To-Do"
                    TextColor="White"
                    BackgroundColor="#4CAF50"
                    CornerRadius="8"
                    Clicked="AddToDoItem"/>

            <!-- Edit + Cancel Buttons (hidden by default) -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" x:Name="editRow" IsVisible="False">
                <Button Grid.Column="0"
                        x:Name="editBtn"
                        Text="✔ Save Edit"
                        TextColor="White"
                        BackgroundColor="#2196F3"
                        CornerRadius="8"
                        Clicked="EditToDoItem"/>
                <Button Grid.Column="1"
                        x:Name="cancelBtn"
                        Text="✖ Cancel"
                        TextColor="White"
                        BackgroundColor="#F44336"
                        CornerRadius="8"
                        Clicked="CancelEdit"/>
            </Grid>
        </VerticalStackLayout>

        <!-- Empty State -->
        <Label x:Name="emptyLabel"
               Text="No to-do items yet. Add one above!"
               HorizontalOptions="Center"
               TextColor="Gray"
               FontSize="14"
               Margin="0,20,0,0"/>

        <!-- ListView -->
        <ListView x:Name="todoLV"
                  HorizontalOptions="Fill"
                  VerticalOptions="Fill"
                  BackgroundColor="Transparent"
                  SeparatorColor="#E0E0E0"
                  HasUnevenRows="True"
                  ItemTapped="TodoLV_OnItemTapped">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ToDoClass">
                    <ViewCell>
                        <Grid Padding="12,8" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto"
                              RowSpacing="2" BackgroundColor="White" Margin="0,2">

                            <!-- Title -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding title}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#222"
                                   LineBreakMode="TailTruncation"/>

                            <!-- Detail -->
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding detail}"
                                   FontSize="13"
                                   TextColor="#666"
                                   LineBreakMode="TailTruncation"/>

                            <!-- Delete Button -->
                            <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                    Text="🗑"
                                    FontSize="18"
                                    BackgroundColor="Transparent"
                                    TextColor="#F44336"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    CommandParameter="{Binding id}"
                                    Clicked="DeleteToDoItem"/>
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </VerticalStackLayout>
</ContentPage>