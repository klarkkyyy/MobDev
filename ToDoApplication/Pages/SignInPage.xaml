<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="ToDoApplication.Pages.SignInPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource Gray100}">

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Label Text="Welcome Back" FontSize="28" Grid.Row="0" HorizontalOptions="Center" TextColor="{StaticResource Primary}" />

        <Frame Grid.Row="1" Padding="20" CornerRadius="12" HasShadow="True" BackgroundColor="{StaticResource White}">
            <VerticalStackLayout Spacing="12">
                <Entry Placeholder="Email" Keyboard="Email" TextColor="{StaticResource Black}" PlaceholderColor="{StaticResource Gray400}" />
                <Entry Placeholder="Password" IsPassword="True" TextColor="{StaticResource Black}" PlaceholderColor="{StaticResource Gray400}" />

                <Button Text="Sign In" Clicked="OnSignInClicked" BackgroundColor="{StaticResource Primary}" TextColor="White" />

                <HorizontalStackLayout HorizontalOptions="Center">
                    <Label Text="Don't have an account?" VerticalOptions="Center" TextColor="{StaticResource Gray600}" />
                    <Button Text="Sign Up" Clicked="OnSignUpClicked" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>
    </Grid>

</ContentPage>