<?xml version="1.0" encoding="utf-8"?>

<ContentPage
    x:Class="ToDoApplication.Pages.AddToDoPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Label Text="Add Task" FontSize="22" Grid.Row="0" HorizontalOptions="Start" />

        <Frame Grid.Row="1" CornerRadius="10" Padding="12" HasShadow="True" BackgroundColor="{StaticResource White}">
            <VerticalStackLayout Spacing="10">
                <Entry x:Name="nameEntry" Placeholder="Task Name" TextColor="{StaticResource Black}" />
                <Editor x:Name="descEntry" Placeholder="Description" AutoSize="TextChanges" HeightRequest="100" TextColor="{StaticResource Black}" />
                <Button Text="Save" Clicked="OnSaveClicked" BackgroundColor="{StaticResource Primary}" TextColor="White" />
            </VerticalStackLayout>
        </Frame>
    </Grid>

</ContentPage>