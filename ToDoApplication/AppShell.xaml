<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ToDoApplication.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:ToDoApplication.Pages">
    <!-- Use Flyout (sidebar) navigation instead of bottom TabBar -->
    <FlyoutItem Title="ToDo" FlyoutDisplayOptions="AsSingleItem">
        <ShellContent Title="ToDo" ContentTemplate="{DataTemplate pages:ToDoPage}" />
    </FlyoutItem>
    <FlyoutItem Title="Starred" FlyoutDisplayOptions="AsSingleItem">
        <ShellContent Title="Starred" ContentTemplate="{DataTemplate pages:StarredPage}" />
    </FlyoutItem>
    <FlyoutItem Title="Completed" FlyoutDisplayOptions="AsSingleItem">
        <ShellContent Title="Completed" ContentTemplate="{DataTemplate pages:CompletedPage}" />
    </FlyoutItem>
    <FlyoutItem Title="Profile" FlyoutDisplayOptions="AsSingleItem">
        <ShellContent Title="Profile" ContentTemplate="{DataTemplate pages:ProfilePage}" />
    </FlyoutItem>
</Shell>